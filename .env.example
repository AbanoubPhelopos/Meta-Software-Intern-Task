# Application
NODE_ENV=development
PORT=3000

# Database — local Docker matches docker-compose.yml; for Vercel/Neon/Supabase, paste the pooled URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/blog_db?schema=public"

# Direct (non-pooled) URL — only set this if your provider requires a separate URL for migrations.
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/blog_db?schema=public"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string-min-32-characters
JWT_EXPIRES_IN=7d

# Security
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000

# Rate limiting on /auth/* — 10 attempts per 15 minutes per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=info
